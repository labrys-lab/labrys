# ── Wazuh API ─────────────────────────────────────────────────────────────────
# Full URL of the Wazuh Manager REST API (including port).
WAZUH_API_URL=https://wazuh-manager:55000

# Credentials — must match WAZUH_API_USERNAME / WAZUH_API_PASSWORD in the root .env
WAZUH_API_USERNAME=wazuh-wui
WAZUH_API_PASSWORD=

# ── Docker ────────────────────────────────────────────────────────────────────
# Path to the Docker socket (bind-mounted into the container).
DOCKER_SOCKET=unix:///var/run/docker.sock

# Must match the `name:` field at the top of docker-compose.yml
COMPOSE_PROJECT_NAME=soc-lab

# ── Paths ─────────────────────────────────────────────────────────────────────
# Path to the scenarios/ directory, relative to the api/ working directory.
SCENARIOS_DIR=../scenarios
