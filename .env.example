# SOC Lab — Environment Variables
# Usage: cp .env.example .env  then edit .env before running docker compose up
# NEVER commit .env to version control.

# ── OpenSearch ────────────────────────────────────────────────────────────────

# JVM heap size for OpenSearch. Set to ~50% of available RAM.
# Minimum: 512m  |  Recommended: 2g or higher
OPENSEARCH_HEAP=2g

# Admin password for OpenSearch (required in OpenSearch 2.12+).
# Must be ≥8 chars and include uppercase, lowercase, a number, and a special character.
# WARNING: Change this before starting the stack.
OPENSEARCH_INITIAL_ADMIN_PASSWORD=ChangeMe!2024

# ── Wazuh API ─────────────────────────────────────────────────────────────────

# Wazuh REST API username used by FastAPI for alert polling.
WAZUH_API_USERNAME=wazuh-wui

# Wazuh REST API password.
# Must be ≥8 chars and include at least one uppercase letter and one number.
# WARNING: Change this before starting the stack.
WAZUH_API_PASSWORD=ChangeMe!2024

# ── Samba Active Directory ────────────────────────────────────────────────────

# NetBIOS domain name. Use uppercase letters only, max 15 characters.
SAMBA_DOMAIN=LABRYS

# Full DNS realm. Must start with the value of SAMBA_DOMAIN (case-insensitive).
SAMBA_REALM=LAB.LABRYS.LOCAL

# AD Administrator password. Must meet Windows complexity requirements:
# ≥8 chars, uppercase, lowercase, number, and a special character.
# WARNING: Change this before starting the stack.
SAMBA_ADMIN_PASSWORD=ChangeMe!2024

# DNS forwarder used by the AD DC for external name resolution.
SAMBA_DNS_FORWARDER=8.8.8.8

# ── Caddy / Web UI ────────────────────────────────────────────────────────────

# Domain served by the Caddy reverse proxy.
# Use "localhost" for local development. Set to a real domain for production.
LAB_DOMAIN=localhost
